# Enforce LF line endings for all source files
* text=auto

*.py text eol=lf
*.html text eol=lf
*.css text eol=lf
*.txt text eol=lf
*.md text eol=lf
*.gitignore text eol=lf
*.gitattributes text eol=lf
*.cfg text eol=lf
*.toml text eol=lf
*.ini text eol=lf

# Binaries — no line-ending conversion
*.db binary
*.png binary
*.jpg binary
*.ico binary
